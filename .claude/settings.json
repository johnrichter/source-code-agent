{
  "effortLevel": "medium",
  "enabledPlugins": {
    "anthropic-info@jr-claude-plugins": true,
    "authoring-governance@jr-claude-plugins": true,
    "authoring-strategy@jr-claude-plugins": true,
    "claude-mem-tools@jr-claude-plugins": true,
    "code-authoring@jr-claude-plugins": true,
    "delivery-agent-team@jr-claude-plugins": true,
    "framework-conventions@jr-claude-plugins": true,
    "git-governance@jr-claude-plugins": true,
    "model-tiering@jr-claude-plugins": true,
    "navigator@jr-claude-plugins": true,
    "rule-tooling@jr-claude-plugins": true,
    "writing-voice@jr-claude-plugins": true
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "mcp__plugin_claude-mem_mcp-search__get_observations",
      "mcp__plugin_claude-mem_mcp-search__search"
    ],
    "ask": [],
    "defaultMode": "auto",
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm -r -f *)",
      "Bash(rm -f -r *)",
      "Bash(rm --recursive --force *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(sudo *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(mkfs.* *)",
      "Bash(chmod 777 *)",
      "Bash(chmod -R 777 *)",
      "Bash(chmod -R 777*)",
      "Bash(chmod 0777 *)",
      "Bash(chown -R *)",
      "Bash(curl * | sh)",
      "Bash(curl * | sh *)",
      "Bash(curl * | bash)",
      "Bash(curl * | bash *)",
      "Bash(wget * | sh)",
      "Bash(wget * | sh *)",
      "Bash(wget * | bash)",
      "Bash(wget * | bash *)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git push * --force*)",
      "Bash(git push * -f *)",
      "Bash(git push * +*)",
      "Bash(git push origin +*)",
      "Bash(git reset --hard origin/main*)",
      "Bash(git clean -fdx*)",
      "Bash(git clean -xfd*)",
      "Bash(> /dev/sd*)",
      "Bash(mv * /dev/null)",
      "Bash(find /)",
      "Bash(find ~/)"
